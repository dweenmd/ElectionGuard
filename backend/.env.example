# --- Database ---------------------------------------------------------
# Local Postgres (see SETUP.md for Docker one-liner):
DATABASE_URL="postgresql://electionguard:electionguard@localhost:5432/electionguard?schema=public"
# Managed Postgres (Neon/Supabase/RDS) — ALWAYS require TLS in production:
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- Security keys ------------------------------------------------------
# Generate each with:  openssl rand -base64 32
# ENCRYPTION_KEY: AES-256-GCM key used to encrypt NID / biometric metadata at rest.
ENCRYPTION_KEY=""
# HMAC_KEY: separate key used only to build a searchable, non-reversible NID index.
HMAC_KEY=""
# JWT_SECRET: signs voter session tokens.
JWT_SECRET=""

# --- Server ---------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- Blockchain (unchanged from before) ------------------------------
RPC_URL="http://127.0.0.1:8545"
CONTRACT_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"
